# Copy to .env.staging on the staging host. Never commit real secrets.

# Core
DJANGO_SETTINGS_MODULE=config.settings.production
DEPLOY_ENVIRONMENT=staging
DEBUG=False
SECRET_KEY=replace-with-staging-secret
APP_VERSION=1.0.0-rc
API_VERSION=1.0.0
GIT_SHA=replace-with-build-sha
BUILD_DATE=2026-07-12T00:00:00Z
RELEASE_NOTES_URL=docs/release-candidate-1.0.md
ALLOWED_HOSTS=staging.tcareer.example,api.staging.tcareer.example
FRONTEND_URL=https://staging.tcareer.example
NEXT_PUBLIC_API_URL=https://staging.tcareer.example/api/v1

# Database
POSTGRES_DB=tcareer_staging
POSTGRES_USER=tcareer_staging
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://tcareer_staging:replace-me@db:5432/tcareer_staging

# Redis cache, throttling, and Celery broker
REDIS_PASSWORD=replace-me
REDIS_URL=redis://:replace-me@redis:6379/0
CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://:replace-me@redis:6379/0
CELERY_BROKER_URL=redis://:replace-me@redis:6379/0
CELERY_RESULT_BACKEND=redis://:replace-me@redis:6379/0

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Lax
CORS_ALLOWED_ORIGINS=https://staging.tcareer.example
CSRF_TRUSTED_ORIGINS=https://staging.tcareer.example
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email provider in staging/test mode only
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.staging-provider.example
EMAIL_PORT=587
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=T-Career Staging <noreply@staging.tcareer.example>
EMAIL_WEBHOOK_ALLOW_SHARED_SECRET=False
SES_WEBHOOK_SECRET=
SENDGRID_WEBHOOK_SECRET=
MAILGUN_WEBHOOK_SIGNING_KEY=

# Sentry or equivalent observability
SENTRY_DSN=
SENTRY_RELEASE=1.0.0-rc
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1

# Storage: use dedicated staging buckets or isolated prefixes
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=tcareer-staging-public
AWS_S3_VERIFICATION_BUCKET=tcareer-staging-private
AWS_S3_CUSTOM_DOMAIN=
STAGING_STORAGE_PREFIX=staging/

# Stripe test mode only
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Restricted AI provider
AI_DEFAULT_PROVIDER=mock
AI_ENABLE_REAL_PROVIDERS=False
AI_REQUEST_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AI_DAILY_STAGING_BUDGET_USD=25

# Retention: dry-run first, no broad deletion by default
AUDIT_RETENTION_ENABLED=False
AUDIT_RETENTION_DAYS=0
RETENTION_DEFAULT_DAYS=365
RETENTION_ANALYTICS_EVENTS_DAYS=730
RETENTION_NOTIFICATIONS_DAYS=365
RETENTION_EMAIL_DELIVERIES_DAYS=365
RETENTION_AI_REQUESTS_DAYS=365
RETENTION_RAG_RETRIEVAL_DAYS=365
RETENTION_EXPORT_FILES_DAYS=30
RETENTION_IMPORT_FILES_DAYS=30
RETENTION_FAILED_WORKER_JOBS_DAYS=90

# Runtime sizing for controlled pilot rehearsal
APP_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443
WEB_CONCURRENCY=3
WEB_THREADS=2
CELERY_CONCURRENCY=2
