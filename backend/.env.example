# ─── Django Core ────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

#  Database 
# Full DATABASE_URL overrides individual fields below
DATABASE_URL=postgresql://tcareer_user:tcareer_pass@db:5432/tcareer

#  Redis
REDIS_URL=redis://:tcareer_redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:tcareer_redis_pass@redis:6379/1

#  AWS 
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=tcareer-media-dev
AWS_S3_CUSTOM_DOMAIN=

#  Google OAuth 
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

#  OpenAI 
OPENAI_API_KEY=sk-your-openai-api-key

#  Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email (AWS SES) 
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=T-Career <noreply@tcareer.com>
# In production, switch to:
# EMAIL_BACKEND=django_ses.SESBackend
# AWS_SES_REGION_NAME=ap-south-1

# Frontend 
FRONTEND_URL=http://localhost:3000

# Sentry (production only) 
SENTRY_DSN=

#  JWT 
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
